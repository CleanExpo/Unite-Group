# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Source route/lib directories literally named 'build' (e.g. command-centre
# lane routes at src/app/api/**/build/). A global gitignore `build/` pattern on
# some machines silently drops these source files from `git add`. Re-include
# them here (repo .gitignore is read after the global file, so these win),
# while keeping real build artefacts (root /build, .next) ignored.
!apps/web/src/app/**/build/
!apps/web/src/app/**/build/**
!apps/web/src/lib/**/build/
!apps/web/src/lib/**/build/**

.vercel
.env*.local

# Specific subdirectory exclusions
deployment/frontend/node_modules/
deployment/frontend/.next/
landing-page/node_modules/
frontend-minimal/node_modules/

# Review Board metrics (local only — uploaded as CI artifact)
.review-metrics.jsonl

# Sandbox wizard cache (schema dumps + sync state)
.sandbox-cache/

# deepsec security scanner workspace
.deepsec/

# Vercel exports (transient pulls — never canonical)
vercel-export-*/

# Local automation logs
/docs/margot/automation-logs/*.log
/docs/margot/linear-watch-today.md

# Margot overnight evidence trail — append-only logs written by the autonomous
# operator/agent runs. Kept on disk as the local evidence record but no longer
# tracked: they grow unbounded and were bloating git history (~5.5M). Untracked
# 2026-06-30; full history preserved up to that commit. Structured operating
# docs in these dirs (crm-*, *-OPERATING-MODEL.md, etc.) stay tracked.
/docs/margot/overnight-progress-log.md
/docs/margot/morning-report.md
/apps/empire/docs/margot/overnight-progress-log.md
/apps/empire/docs/margot/morning-report.md
/docs/brain/2nd Brain/Decisions/continuous-work-queue.jsonl

# Transient agent run artifacts (raw logs / exit codes — never canonical)
.shipit_evidence/
outputs/sandbox_voice_migration/
