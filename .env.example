YOUTUBE_API_KEY=

# --- Google Analytics 4 + Search Console ---
# value: old unite-hub Vercel project
GA4_PROPERTY_ID=
GSC_PROPERTY_ID=

# --- Gemini (image generation + vision analysis) ---
# value: old unite-hub Vercel project
GEMINI_API_KEY=

# --- Apify (website scraping + screenshots) ---
# value: old unite-hub Vercel project
