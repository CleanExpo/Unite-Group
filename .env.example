# --- Sentry (error tracking) ---
# value: old unite-hub Vercel project
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- MCP endpoint overrides (operator tooling — local/internal URLs) ---
# value: local only / internal network
GITHUB_MCP_URL=
SLACK_MCP_URL=
SUPABASE_MCP_URL=

# --- Operator Gateway (sandbox Supabase project for the operator gateway) ---
# value: old unite-hub Vercel project (sandbox project lksfwktwtmyznckodsau)
OPERATOR_GATEWAY_SANDBOX_SUPABASE_URL=
OPERATOR_GATEWAY_SANDBOX_SUPABASE_ANON_KEY=
# Project ref of the approved sandbox (read by getApprovedSandboxProjectRef,
# lib/operator-gateway/jobs.ts). When unset, no sandbox URL is approved and the
# gateway stays honestly not_connected — provisioning is an env change, not code.
OPERATOR_GATEWAY_SANDBOX_PROJECT_REF=

# --- Hermes / Wiki integration ---
# Path to the local Hermes wiki directory (mount or local clone)
# value: local only
WIKI_PATH=
HERMES_CONFIG=

# --- Knowledge Console (internal feature flag) ---
# Set to "true" to enable the knowledge console preview
# value: local only
KNOWLEDGE_CONSOLE_PREVIEW=


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 4 — apps/workspace (Hermes operator command centre — Vite/React)
# These are set in apps/workspace/.env — NOT needed in the unite-group Vercel
# project (workspace is a local/self-hosted app, not deployed to Vercel prod).
# ─────────────────────────────────────────────────────────────────────────────

# --- Core: Hermes gateway connection ---
# URL of the local Hermes Agent WebAPI gateway (default: http://127.0.0.1:8642)
HERMES_API_URL=http://127.0.0.1:8642
# Bearer token for the Hermes gateway when API_SERVER_KEY is set
HERMES_API_TOKEN=

# --- Hermes session + security ---
HERMES_PASSWORD=
# Hermes agent local installation directory
HERMES_HOME=
HERMES_AGENT_REPO=
HERMES_CLI_BIN=
HERMES_WORKSPACE_DIR=
HERMES_SKILLS_DIR=
HERMES_WEBUI_DEFAULT_WORKSPACE=
HERMES_WORKSPACE_DESKTOP=
HERMES_WORKSPACE_DOCKER=
HERMES_WORKSPACE_METRICS_DISK_PATH=

# --- Hermes Claude/dashboard proxy ---
HERMES_DASHBOARD_TOKEN=
HERMES_DASHBOARD_URL=
HERMES_DEFAULT_MODEL=
HERMES_USE_RESPONSES=
HERMES_TOOL_DEBUG=

# --- Legacy CLAUDE_* aliases (honoured by workspace for back-compat) ---
CLAUDE_PASSWORD=
CLAUDE_API_TOKEN=
CLAUDE_API_URL=
CLAUDE_GATEWAY_URL=
CLAUDE_GATEWAY_TOKEN=
CLAUDE_GATEWAY_PASSWORD=
CLAUDE_DASHBOARD_TOKEN=
CLAUDE_DASHBOARD_URL=
CLAUDE_DEFAULT_MODEL=
CLAUDE_HOME=
CLAUDE_WORKSPACE_DIR=

# --- LLM providers (workspace supports multiple; use whichever is configured) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- GitHub (workspace uses GH_TOKEN or GITHUB_TOKEN for gh CLI calls) ---
GH_TOKEN=
GITHUB_TOKEN=

# --- MCP hub settings ---
MCP_HUB_CACHE_TTL_MS=
MCP_TOOLS_CACHE_TTL_MS=
MCP_PRESETS_SEED_PATH=

# --- Knowledge / local filesystem ---
KNOWLEDGE_DIR=

# --- Network / deployment ---
HOST=127.0.0.1
# PORT default: 3002
PORT=3002
COOKIE_SECURE=
TRUST_PROXY=

# --- SSE stream timeouts (milliseconds) ---
STREAM_ACCEPTED_TIMEOUT_MS=120000
STREAM_HANDOFF_TIMEOUT_MS=300000

# --- Swarm / multi-agent ---
SWARM_MAIN_SESSION_KEY=
SWARM_ORCHESTRATOR_WORKER_ID=

# --- Build / version metadata ---
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_PING_URL=


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 5 — apps/autopilot-runner (OWNEST — DORMANT / NOT ARMABLE)
# This is a name/default registry, not an activation recipe. The former
# user-level LaunchAgent is uninstall-only. Live admission is rejected in code
# until a separate UID, sealed HOME/workspace, brokered CRM credential,
# enforceable tool/egress policy, and independent verifier are installed.
# Reuses SUPABASE_SERVICE_ROLE_KEY and FOUNDER_USER_ID from Sections 1–2;
# never place either value in a Hermes profile or child-process environment.
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=
CC_OWNEST_WORKER_ID=
CC_OWNEST_HERMES_BIN=
HERMES_CWD=

# Kill switches / bounded defaults. CC_OWNEST_LIVE=1 is rejected by code.
CC_OWNEST_LIVE=0
CC_OWNEST_LOCAL_DEVELOPMENT=0
CC_OWNEST_HERMES_PROFILE=ownest
CC_OWNEST_HERMES_BOARD=unite-group-ownest
CC_OWNEST_ROLLOUT_ID=
CC_OWNEST_CANARY_TASK_ID=
CC_OWNEST_CANARY_LIMIT=1
CC_OWNEST_MAX_IN_PROGRESS=1
CC_OWNEST_LEASE_MS=300000
CC_OWNEST_DAILY_DISPATCH_LIMIT=1


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 6 — packages/pi-ceo-operator-mcp
# Uses the operator's local `gh` CLI session for GitHub API calls.
# No secret env vars required at runtime — gh auth is ambient.
# NODE_ENV controls whether the Vite manifest is loaded.
# ─────────────────────────────────────────────────────────────────────────────

# Standard Node runtime env — no custom vars required by this package.
# NODE_ENV=production  (set by build tooling)


