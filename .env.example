# ============================================================
# Unite-Group Monorepo — Canonical Environment Variable Registry
# ============================================================
# This is the SINGLE SOURCE OF TRUTH for all environment variable
# names across the monorepo. Secret values NEVER appear here.
#
# Each entry shows:
#   - what the variable does
#   - which package(s) use it
#   - where today's live value lives
#
# Sections:
#   1. Shared/critical  — apps/web production (Supabase + Anthropic core)
#   2. apps/web required — blocks full feature use if absent
#   3. apps/web integrations — optional, degrade gracefully
#   4. apps/workspace — Hermes operator command centre (Vite/React)
#   5. apps/autopilot-runner — dormant OWNEST host profile
#   6. packages/pi-ceo-operator-mcp — portfolio health MCP server
#   7. Test/CI — never deployed to Vercel production
#   8. Legacy/retired — listed for Vercel cleanup only, NOT needed by monorepo
# ============================================================


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 1 — Shared / Critical (apps/web production)
# All three are required for apps/web to boot. Copy from the old unite-hub
# Vercel project into the unite-group Vercel project during Step 1 of the
# cutover runbook.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase public endpoint — value: old unite-hub Vercel project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key — value: old unite-hub Vercel project
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (server-side only, bypasses RLS) — value: old unite-hub Vercel project
SUPABASE_SERVICE_ROLE_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 2 — apps/web Required (blocks features if absent)
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — powers Bron AI, Advisory, Strategy, content generation
# value: old unite-hub Vercel project
ANTHROPIC_API_KEY=

# AES-256-GCM encryption key for the credentials vault (generate: openssl rand -hex 32)
# value: old unite-hub Vercel project
VAULT_ENCRYPTION_KEY=

# Secret for validating scheduled-job (cron) route calls
# value: old unite-hub Vercel project
CRON_SECRET=

# Supabase auth.users UUID for the founder — used by cron jobs
# value: old unite-hub Vercel project
FOUNDER_USER_ID=

# Canonical app URL for OAuth callbacks and absolute links
# value: old unite-hub Vercel project (https://unite-group.in in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Direct PostgreSQL connection string (Supabase "Direct connection")
# value: old unite-hub Vercel project
DATABASE_URL=

# DB connection-pool settings (used with DATABASE_URL)
# value: local only / set per-environment as needed
ENABLE_DB_POOLER=false
DB_POOL_SIZE=10
DB_POOLER_MODE=transaction
DB_IDLE_TIMEOUT=30
DB_MAX_LIFETIME=3600


# ─────────────────────────────────────────────────────────────────────────────
# SECTION 3 — apps/web Integrations (optional, degrade gracefully)
# ─────────────────────────────────────────────────────────────────────────────

