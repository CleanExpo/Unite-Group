TEST_FOUNDER_EMAIL=
TEST_FOUNDER_PASSWORD=
UNITE_HUB_BASE_URL=http://localhost:3000
UNITE_HUB_TEST_MOCK_AI_FILES=
UNITE_HUB_TEST_MOCK_TRANSCRIPTION=


