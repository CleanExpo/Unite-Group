# Copy to .env.local for local dev. In production these live in Vercel
# environment variables (server-side only) — never in the browser or the repo.

# ── Engine provider routing ─────────────────────────────────────────────
# Which plan pays for engine runs: anthropic | openrouter | minimax
# (Phase 0 runs in Claude Code/Cowork ride your Max plan and ignore this.)
LLM_PROVIDER=anthropic

# Anthropic API — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# OpenRouter — used when LLM_PROVIDER=openrouter (metered bridge)
OPENROUTER_API_KEY=
# Comma-separated slugs from openrouter.ai/models — first is primary, the
# rest are automatic fallbacks (recommended when leading with a :free model)
OPENROUTER_MODEL=nex-agi/nex-n2-pro:free,moonshotai/kimi-k2.6

# MiniMax — used when LLM_PROVIDER=minimax (also the default critic)
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2

# ── Phase 3: 2nd Brain vault link ────────────────────────────────────────
# The Obsidian vault repo the app ingests (owner/repo) and a fine-grained
# GitHub token with read-only Contents access to that one repo.
KNOWLEDGE_REPO=CleanExpo/brain-1
GITHUB_TOKEN=

# ── Phase 2 critic (verify loop) ─────────────────────────────────────────
# A second model reviews every spec before you see it. Defaults to the first
# configured of: minimax → openrouter → anthropic. Set "off" to disable.
# CRITIC_PROVIDER=minimax
# CRITIC_MODEL=

# Supabase — Postgres for visions and specs (optional; the app runs without it
# and simply skips saving)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
