{
  "name": "unite-group",
  "version": "1.0.0",
  "private": true,
  "description": "Unite Hub — AI-Powered CRM & Marketing Automation. Next.js 16 + Supabase PostgreSQL.",
  "author": "Unite Group",
  "license": "ISC",
  "scripts": {
    "dev": "next dev -p 3008",
    "dev:all": "turbo run dev",
    "prebuild": "node scripts/sync-portfolio-registry.mjs && node scripts/validate-env.mjs --ci",
    "build": "next build",
    "validate:env": "node scripts/validate-env.mjs",
    "build:all": "turbo run build",
    "lint": "eslint src/",
    "lint:all": "turbo run lint",
    "type-check": "tsc --noEmit",
    "type-check:all": "turbo run type-check",
    "test": "vitest run",
    "test:all": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "turbo run test:coverage",
    "clean": "rm -rf .next out dist",
    "clean:all": "turbo run clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose restart",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "deps:check": "bash scripts/dependency-checks.sh",
    "prepare": "husky || true",
    "linear": "node scripts/linear-update.mjs",
    "mobile-voice:approve-board-packet": "tsx scripts/mobile-voice-approve-board-packet.ts",
    "mobile-voice:terminal-exchange": "tsx scripts/mobile-voice-terminal-exchange.ts",
    "test:e2e": "playwright test",
    "test:e2e:contact-crud": "tsx e2e/support/run-with-supabase-admin.ts playwright test e2e/contact-crud.spec.ts",
    "test:e2e:lead-scoring": "tsx e2e/support/run-with-supabase-admin.ts playwright test e2e/lead-scoring.spec.ts",
    "test:e2e:file-upload": "UNITE_HUB_TEST_MOCK_AI_FILES=1 tsx e2e/support/run-with-supabase-admin.ts playwright test e2e/file-upload.spec.ts",
    "test:e2e:transcription": "UNITE_HUB_TEST_MOCK_AI_FILES=1 UNITE_HUB_TEST_MOCK_TRANSCRIPTION=1 tsx e2e/support/run-with-supabase-admin.ts playwright test e2e/transcription.spec.ts",
    "test:e2e:drip-campaign": "tsx e2e/support/run-with-supabase-admin.ts playwright test e2e/drip-campaign.spec.ts",
    "test:e2e:email-import": "tsx e2e/support/run-with-supabase-admin.ts playwright test e2e/email-import.spec.ts",
    "test:e2e:core-journeys": "tsx e2e/support/run-with-supabase-admin.ts playwright test e2e/core-journeys.spec.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/mcp": "^0.0.77",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^26.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.0",
    "autoprefixer": "^10.5.2",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "critters": "^0.0.25",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^13.0.3",
    "gray-matter": "^4.0.3",
    "inquirer": "^13.2.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "open": "^11.0.0",
    "ora": "^8.1.1",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^3.5.0",
    "supabase": "^2.109.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.0",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^1.6.1",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.4.0",
    "@linear/sdk": "^88.0.0",
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sendgrid/mail": "^8.1.6",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.7.5",
    "apify-client": "^2.23.4",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "framer-motion": "^12.42.2",
    "geist": "^1.7.2",
    "google-auth-library": "^10.9.0",
    "imapflow": "^1.4.6",
    "lucide-react": "^1.23.0",
    "nanoid": "^5.1.16",
    "next": "^16.2.10",
    "novel": "^1.0.2",
    "react": "^19.2.7",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "xero-node": "^13.3.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.7",
    "stripe": "^22.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "neverBuiltDependencies": [
      "supabase"
    ],
    "overrides": {
      "happy-dom": ">=20.0.0"
    }
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      "chrome >= 95",
      "firefox >= 95",
      "safari >= 15",
      "edge >= 95"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
