# ============================================================
# Unite-Group Nexus 2.0 — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic API — commercial, metered server route.
# Do not place Claude Free/Pro/Max consumer-session credentials in apps/web.
# Claude Code plan capacity belongs only to an independently attested local CLI lane.
ANTHROPIC_API_KEY=

# Xero — Accounting (Phase 4)
# CARSI Xero Account (carsi, restore, ato, synthex, ccw, dr_qld-fallback)
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# DR Xero Account (dr, nrpg, dr_qld)
DR_CLIENT_ID=your-dr-client-id
DR_CLIENT_SECRET=your-dr-client-secret
# Per-tenant Xero org ids for contact/accounting sync (one per connected business)
XERO_TENANT_ID_DR=
XERO_TENANT_ID_CARSI=
# Webhook signing key — validates inbound Xero callbacks (src/lib/integrations/xero/health.ts)
XERO_WEBHOOK_KEY=

# Google — Gmail + Calendar + Drive (Phase 4)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_VAULT_FOLDER_ID=your-google-drive-folder-id

# Microsoft 365 — OAuth (src/app/api/auth/microsoft/authorize)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Linear — Project Management (Phase 4)
LINEAR_API_KEY=lin_api_xxx


# Credentials Vault — AES-256-GCM encryption
# Generate key with: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=your-64-char-hex-key-here

# CRON / Scheduled Tasks
CRON_SECRET=your-cron-secret-here

# Founder allow-list — controls who may enter the private CRM (proxy.ts step 4,
# src/lib/auth/private-access.ts) AND which auth user the CRONs act as.
# Precedence: FOUNDER_ALLOWED_USER_IDS overrides FOUNDER_USER_ID;
#             FOUNDER_ALLOWED_EMAILS  overrides ALLOWED_FOUNDER_EMAILS.
# Values are comma-separated, trimmed, and matched case-insensitively.
# FOUNDER_USER_ID must be the auth.users.id of the account the founder ACTUALLY
# signs in with (Supabase dashboard → Authentication → Users) — a stale UID here
# locks the founder out (see the 2026-07-14 incident; nightly hub-sweep now
# reports drift as allowListHealth).
# WINDOWS WARNING: `echo value | vercel env add …` appends a literal \r\n and
# silently breaks matching. Use: printf '%s' "value" | vercel env add NAME production
FOUNDER_USER_ID=your-supabase-user-uuid
FOUNDER_ALLOWED_EMAILS=founder@example.com

# Database — Direct PostgreSQL connection + Connection Pooling (PgBouncer)
# Use the Supabase "Direct connection" string for DATABASE_URL
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Set ENABLE_DB_POOLER=true to use Supabase Pooler (60-80% latency reduction)
ENABLE_DB_POOLER=false
DB_POOL_SIZE=10
DB_POOLER_MODE=transaction
DB_IDLE_TIMEOUT=30
DB_MAX_LIFETIME=3600

# Google Search Console + Analytics 4
GSC_PROPERTY_ID=        # sc-domain:example.com or https://example.com/
GA4_PROPERTY_ID=        # Format: 123456789

# YouTube Data API (separate from Google OAuth)
YOUTUBE_API_KEY=

# Social Platforms
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# YouTube uses existing GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET

# Reddit — Social monitoring + content analysis
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# SendGrid — Transactional email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Slack — Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
SLACK_DEFAULT_CHANNEL=#nexus-alerts
# Bot token for the Slack MCP server auth (src/lib/ai/features/mcp.ts)
SLACK_BOT_TOKEN=

# MCP servers — remote tool endpoints consumed by AI features (src/lib/ai/features/mcp.ts)
GITHUB_MCP_URL=
SLACK_MCP_URL=
SUPABASE_MCP_URL=

# Telegram — approval-flow messaging + signed decision callbacks
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Signing key validating Telegram decision callbacks (src/app/api/telegram/approval-callback)
TELEGRAM_DECISION_SIGNING_KEY=

# Pi-CEO — activity / portfolio-health service
PI_CEO_API_URL=
PI_CEO_API_KEY=

# Media / Research AI providers
# ElevenLabs — Margot voice (TTS) + webhook ingest
ELEVENLABS_API_KEY=
ELEVENLABS_INGEST_TOKEN=
ELEVENLABS_MARGOT_AGENT_ID=
# HeyGen — video composition + rendering
HEYGEN_API_KEY=
# HMAC-SHA256 key for verifying x-heygen-signature on /api/webhooks/heygen (UNI-2224)
HEYGEN_WEBHOOK_SECRET=
# Hugging Face — external knowledge research
HF_API_TOKEN=
# Perplexity — citation/research validation
PERPLEXITY_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public base URL for wiki links + canonical URLs (src/app/(founder)/founder/wiki)
NEXT_PUBLIC_SITE_URL=

# Feature flags + tuning
# Set to 1 to expose the /preview/knowledge-console route
KNOWLEDGE_CONSOLE_PREVIEW=

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Playwright E2E Testing
PLAYWRIGHT_TEST_EMAIL=your-test-email@example.com
PLAYWRIGHT_TEST_PASSWORD=your-test-password
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# WhatsApp Cloud API (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# GitHub
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=phill-mcgurk
# HMAC signing key validating inbound GitHub webhooks (src/app/api/webhooks/github)
GITHUB_WEBHOOK_SECRET=

# Gemini — Image generation + vision analysis
GEMINI_API_KEY=

# Apify — Website scraping + screenshot capture
APIFY_API_TOKEN=

# PaperBanana — Academic diagram/infographic generation (optional)
# When absent, all visual types fall back to Gemini
PAPER_BANANA_URL=
