# Unite-Group — AI Front Desk env (EXAMPLE — copy real values into your env store)
# Feature flag. Absent/false = fully dark (no front-desk surface). Set true to enable.
UNITE_FRONT_DESK_ENABLED=false

# Managed media vendor (anchor at kickoff: ElevenLabs or Vapi)
# ELEVENLABS_API_KEY=          # Unite-Group already uses ElevenLabs? reuse; else provision
# ELEVENLABS_FRONTDESK_VOICE_ID=
# VAPI_API_KEY=

# Telephony (BYO SIP — Twilio or Telnyx) for the AU number
# FRONTDESK_PHONE_NUMBER=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TELNYX_API_KEY=

# LLM (reuse this app's provider where possible)
# OPENROUTER_API_KEY= / OPENAI_API_KEY=
