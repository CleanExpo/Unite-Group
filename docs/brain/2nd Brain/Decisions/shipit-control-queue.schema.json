{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unite-group.local/schemas/shipit-control-queue.schema.json",
  "title": "Shipit Control Queue Item",
  "description": "One JSONL row for Hermes Shipit Control queue.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "product",
    "repo",
    "role",
    "title",
    "priority",
    "status",
    "acceptance",
    "next_action",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^UGN-[0-9]{3,}$",
      "description": "Stable task identifier, e.g. UGN-001"
    },
    "product": { "type": "string", "minLength": 1 },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$",
      "description": "owner/repo format"
    },
    "role": {
      "type": "string",
      "enum": [
        "research_lead",
        "design_content",
        "engineer",
        "senior_engineer",
        "pm",
        "designer",
        "qa",
        "ops",
        "security",
        "founder"
      ]
    },
    "title": { "type": "string", "minLength": 5 },
    "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "status": {
      "type": "string",
      "enum": ["todo", "in_progress", "need_approval", "blocked", "blocked_stale", "done", "cancelled"]
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "next_action": { "type": "string", "minLength": 3 },
    "escalate_if_blocked_hours": { "type": "integer", "minimum": 1, "maximum": 168, "default": 6 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "eta": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "blocked_at": { "type": "string", "format": "date-time" },
    "owner": { "type": "string", "minLength": 1, "description": "Assigned agent/person identifier" },
    "approval_request": { "type": "string", "minLength": 3 },
    "blocked_reason": { "type": "string", "minLength": 3 },
    "required_human_action": { "type": "string", "minLength": 3 },
    "artifact_paths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "labels": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "dependencies": { "type": "array", "items": { "type": "string", "pattern": "^UGN-[0-9]{3,}$" }, "default": [] },
    "stale_after_hours": { "type": "integer", "minimum": 1, "maximum": 168, "default": 4, "description": "If in_progress with no new artifact beyond this window, auto-escalate to blocked_stale" },
    "last_artifact_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    { "if": { "properties": { "status": { "const": "in_progress" } }, "required": ["status"] }, "then": { "required": ["started_at", "owner", "eta"] } },
    { "if": { "properties": { "status": { "const": "done" } }, "required": ["status"] }, "then": { "required": ["completed_at", "artifact_paths"] } },
    { "if": { "properties": { "status": { "enum": ["blocked", "blocked_stale"] } }, "required": ["status"] }, "then": { "required": ["blocked_reason", "blocked_at", "required_human_action"] } },
    { "if": { "properties": { "status": { "const": "need_approval" } }, "required": ["status"] }, "then": { "required": ["approval_request", "required_human_action"] } }
  ]
}
