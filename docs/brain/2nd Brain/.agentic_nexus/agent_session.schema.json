{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unite-group-nexus.local/schemas/agentic-nexus/agent_session.schema.json",
  "title": "Agentic Nexus Agent Session Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "agent_id",
    "agent_type",
    "assigned_project",
    "assigned_task",
    "requested_scopes",
    "granted_scopes",
    "denied_scopes",
    "worker_id",
    "session_start_time",
    "session_status",
    "human_owner",
    "approval_status",
    "evidence_required",
    "diagnostic_gate_completed",
    "risk_level",
    "escalation_required",
    "session_expiry",
    "audit_log_reference"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "pattern": "^ANX-SESSION-[A-Za-z0-9._-]+$"
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_type": {
      "enum": [
        "Hermes CEO Orchestrator",
        "Senior Project Manager Agent",
        "Context Discovery Agent",
        "Purpose Mapping Agent",
        "Friction Mapping Agent",
        "Research Director Agent",
        "Evidence Validator Agent",
        "Principal Software Engineer Agent",
        "QA/Test Agent",
        "UI/UX Review Agent",
        "SEO/AEO/GEO Agent",
        "Marketing Strategy Agent",
        "Brand Authority Agent",
        "Business Operations Agent",
        "Finance Awareness Agent",
        "Legal/Compliance Awareness Agent",
        "Documentation Agent",
        "Dashboard Reporter Agent",
        "Local Build Worker",
        "Local Research Worker"
      ]
    },
    "assigned_project": {
      "type": "string",
      "minLength": 1
    },
    "assigned_task": {
      "type": "string",
      "minLength": 1
    },
    "requested_scopes": {
      "type": "array",
      "items": {
        "enum": [
          "read:project_registry",
          "read:agent_registry",
          "read:task_queue",
          "read:obsidian_memory",
          "read:github_repository",
          "read:dashboard_status",
          "read:evidence_ledger",
          "read:decision_register",
          "read:business_goals",
          "write:task_status",
          "write:structured_obsidian_note",
          "write:evidence_record",
          "write:gap_report",
          "write:decision_draft",
          "write:dashboard_status",
          "write:branch_commit",
          "write:pull_request_draft",
          "write:qa_report",
          "run:lint",
          "run:typecheck",
          "run:tests",
          "run:build",
          "run:playwright",
          "run:local_script",
          "run:research_task",
          "run:gap_analysis",
          "run:shipit_readiness_check",
          "merge:pull_request",
          "deploy:production",
          "publish:public_content",
          "send:external_email",
          "modify:billing",
          "modify:authentication",
          "modify:database_policy",
          "modify:rls_policy",
          "delete:file",
          "delete:database_record",
          "access:customer_personal_data",
          "access:payment_data",
          "change:legal_or_compliance_position"
        ]
      },
      "uniqueItems": true
    },
    "granted_scopes": {
      "type": "array",
      "items": {
        "enum": [
          "read:project_registry",
          "read:agent_registry",
          "read:task_queue",
          "read:obsidian_memory",
          "read:github_repository",
          "read:dashboard_status",
          "read:evidence_ledger",
          "read:decision_register",
          "read:business_goals",
          "write:task_status",
          "write:structured_obsidian_note",
          "write:evidence_record",
          "write:gap_report",
          "write:decision_draft",
          "write:dashboard_status",
          "write:branch_commit",
          "write:pull_request_draft",
          "write:qa_report",
          "run:lint",
          "run:typecheck",
          "run:tests",
          "run:build",
          "run:playwright",
          "run:local_script",
          "run:research_task",
          "run:gap_analysis",
          "run:shipit_readiness_check",
          "merge:pull_request",
          "deploy:production",
          "publish:public_content",
          "send:external_email",
          "modify:billing",
          "modify:authentication",
          "modify:database_policy",
          "modify:rls_policy",
          "delete:file",
          "delete:database_record",
          "access:customer_personal_data",
          "access:payment_data",
          "change:legal_or_compliance_position"
        ]
      },
      "uniqueItems": true
    },
    "denied_scopes": {
      "type": "array",
      "items": {
        "enum": [
          "read:project_registry",
          "read:agent_registry",
          "read:task_queue",
          "read:obsidian_memory",
          "read:github_repository",
          "read:dashboard_status",
          "read:evidence_ledger",
          "read:decision_register",
          "read:business_goals",
          "write:task_status",
          "write:structured_obsidian_note",
          "write:evidence_record",
          "write:gap_report",
          "write:decision_draft",
          "write:dashboard_status",
          "write:branch_commit",
          "write:pull_request_draft",
          "write:qa_report",
          "run:lint",
          "run:typecheck",
          "run:tests",
          "run:build",
          "run:playwright",
          "run:local_script",
          "run:research_task",
          "run:gap_analysis",
          "run:shipit_readiness_check",
          "merge:pull_request",
          "deploy:production",
          "publish:public_content",
          "send:external_email",
          "modify:billing",
          "modify:authentication",
          "modify:database_policy",
          "modify:rls_policy",
          "delete:file",
          "delete:database_record",
          "access:customer_personal_data",
          "access:payment_data",
          "change:legal_or_compliance_position"
        ]
      },
      "uniqueItems": true
    },
    "worker_id": {
      "type": "string",
      "minLength": 1
    },
    "session_start_time": {
      "type": "string",
      "format": "date-time"
    },
    "session_status": {
      "enum": [
        "requested",
        "diagnostic_pending",
        "approval_pending",
        "active",
        "completed",
        "denied",
        "expired",
        "revoked"
      ]
    },
    "human_owner": {
      "type": "string",
      "const": "Phill McGurk"
    },
    "approval_status": {
      "enum": [
        "not_required",
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "enum": [
          "research",
          "coding",
          "business_strategy",
          "compliance",
          "dashboard",
          "qa",
          "decision",
          "gap_report"
        ]
      },
      "uniqueItems": true
    },
    "diagnostic_gate_completed": {
      "type": "boolean"
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "escalation_required": {
      "type": "boolean"
    },
    "session_expiry": {
      "type": "string",
      "format": "date-time"
    },
    "audit_log_reference": {
      "type": "string",
      "minLength": 1
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "approval_required": {
      "type": "boolean"
    },
    "requested_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "diagnostic_gate_completed": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "session_status": {
            "enum": [
              "requested",
              "diagnostic_pending",
              "denied"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "risk_level": {
            "enum": [
              "high",
              "critical"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "escalation_required": {
            "const": true
          }
        }
      }
    }
  ]
}
