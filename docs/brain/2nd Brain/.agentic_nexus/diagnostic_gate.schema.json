{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unite-group-nexus.local/schemas/agentic-nexus/diagnostic_gate.schema.json",
  "title": "Agentic Nexus Diagnostic Gate Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagnostic_id",
    "request_id",
    "agent_id",
    "assigned_project",
    "answers",
    "context_discovery_completed",
    "purpose_mapping_completed",
    "friction_mapping_completed",
    "gap_detection_completed",
    "business_value_review_completed",
    "priority_scoring_completed",
    "execution_recommendation",
    "approval_required",
    "evidence_required",
    "next_action"
  ],
  "properties": {
    "diagnostic_id": {
      "type": "string",
      "pattern": "^ANX-DIAGNOSTIC-[A-Za-z0-9._-]+$"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "assigned_project": {
      "type": "string",
      "minLength": 1
    },
    "answers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "What already exists?",
        "What has already been started?",
        "Why was it created?",
        "What problem was it meant to solve?",
        "What friction is it trying to reduce?",
        "What is missing?",
        "What is duplicated?",
        "What is unclear?",
        "What benefits Unite-Group Nexus as a whole?",
        "What is the smallest useful next action?"
      ],
      "properties": {
        "What already exists?": {
          "type": "string",
          "minLength": 1
        },
        "What has already been started?": {
          "type": "string",
          "minLength": 1
        },
        "Why was it created?": {
          "type": "string",
          "minLength": 1
        },
        "What problem was it meant to solve?": {
          "type": "string",
          "minLength": 1
        },
        "What friction is it trying to reduce?": {
          "type": "string",
          "minLength": 1
        },
        "What is missing?": {
          "type": "string",
          "minLength": 1
        },
        "What is duplicated?": {
          "type": "string",
          "minLength": 1
        },
        "What is unclear?": {
          "type": "string",
          "minLength": 1
        },
        "What benefits Unite-Group Nexus as a whole?": {
          "type": "string",
          "minLength": 1
        },
        "What is the smallest useful next action?": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "context_discovery_completed": {
      "type": "boolean",
      "const": true
    },
    "purpose_mapping_completed": {
      "type": "boolean",
      "const": true
    },
    "friction_mapping_completed": {
      "type": "boolean",
      "const": true
    },
    "gap_detection_completed": {
      "type": "boolean",
      "const": true
    },
    "business_value_review_completed": {
      "type": "boolean",
      "const": true
    },
    "priority_scoring_completed": {
      "type": "boolean",
      "const": true
    },
    "execution_recommendation": {
      "enum": [
        "do_not_execute",
        "execute_low_risk",
        "requires_human_approval",
        "needs_more_evidence",
        "create_task_draft"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  }
}
