{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unite-group-nexus.local/schemas/agentic-nexus/approval_gate.schema.json",
  "title": "Agentic Nexus Approval Gate Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "requested_by_agent",
    "requested_action",
    "affected_project",
    "affected_files",
    "affected_systems",
    "risk_level",
    "reason_for_request",
    "evidence_supplied",
    "approval_required_from",
    "approval_status",
    "approved_by",
    "rejected_by",
    "decision_timestamp",
    "decision_notes",
    "expiry",
    "audit_log_reference"
  ],
  "properties": {
    "approval_id": {
      "type": "string",
      "pattern": "^ANX-APPROVAL-[A-Za-z0-9._-]+$"
    },
    "requested_by_agent": {
      "type": "string",
      "minLength": 1
    },
    "requested_action": {
      "type": "string",
      "minLength": 1
    },
    "affected_project": {
      "type": "string",
      "minLength": 1
    },
    "affected_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "affected_systems": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "reason_for_request": {
      "type": "string",
      "minLength": 1
    },
    "evidence_supplied": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "approval_required_from": {
      "type": "array",
      "items": {
        "enum": [
          "Phill McGurk",
          "Board",
          "Legal/Compliance Awareness Agent",
          "Finance Awareness Agent",
          "Security Shepherd",
          "Project Owner"
        ]
      },
      "minItems": 1
    },
    "approval_status": {
      "enum": [
        "not_required",
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "rejected_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision_timestamp": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "decision_notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "expiry": {
      "type": "string",
      "format": "date-time"
    },
    "audit_log_reference": {
      "type": "string",
      "minLength": 1
    }
  }
}
