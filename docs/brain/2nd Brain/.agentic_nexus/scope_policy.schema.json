{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unite-group-nexus.local/schemas/agentic-nexus/scope_policy.schema.json",
  "title": "Agentic Nexus Scope Policy Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scope_name",
    "scope_category",
    "allowed_agent_types",
    "required_approval",
    "evidence_required",
    "risk_level",
    "allowed_contexts",
    "forbidden_contexts",
    "escalation_rule",
    "default_decision"
  ],
  "properties": {
    "scope_name": {
      "type": "string"
    },
    "scope_category": {
      "enum": [
        "read",
        "write",
        "execute",
        "restricted",
        "forbidden"
      ]
    },
    "allowed_agent_types": {
      "type": "array",
      "items": {
        "enum": [
          "Hermes CEO Orchestrator",
          "Senior Project Manager Agent",
          "Context Discovery Agent",
          "Purpose Mapping Agent",
          "Friction Mapping Agent",
          "Research Director Agent",
          "Evidence Validator Agent",
          "Principal Software Engineer Agent",
          "QA/Test Agent",
          "UI/UX Review Agent",
          "SEO/AEO/GEO Agent",
          "Marketing Strategy Agent",
          "Brand Authority Agent",
          "Business Operations Agent",
          "Finance Awareness Agent",
          "Legal/Compliance Awareness Agent",
          "Documentation Agent",
          "Dashboard Reporter Agent",
          "Local Build Worker",
          "Local Research Worker"
        ]
      },
      "uniqueItems": true
    },
    "required_approval": {
      "type": "boolean"
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "allowed_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "forbidden_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "escalation_rule": {
      "type": "string"
    },
    "default_decision": {
      "enum": [
        "allow",
        "deny",
        "requires_human_approval"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope_category": {
            "const": "restricted"
          }
        }
      },
      "then": {
        "properties": {
          "required_approval": {
            "const": true
          },
          "default_decision": {
            "const": "requires_human_approval"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope_category": {
            "const": "forbidden"
          }
        }
      },
      "then": {
        "properties": {
          "default_decision": {
            "const": "deny"
          }
        }
      }
    }
  ]
}
