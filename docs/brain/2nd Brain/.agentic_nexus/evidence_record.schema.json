{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unite-group-nexus.local/schemas/agentic-nexus/evidence_record.schema.json",
  "title": "Agentic Nexus Evidence Record Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "task_id",
    "agent_id",
    "project",
    "evidence_type",
    "source_path",
    "source_url",
    "source_date",
    "date_gathered",
    "claim_supported",
    "confidence_score",
    "freshness_rating",
    "contradiction_status",
    "business_relevance",
    "linked_decision",
    "linked_gap",
    "linked_output",
    "recommended_next_action"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^ANX-EVIDENCE-[A-Za-z0-9._-]+$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "evidence_type": {
      "enum": [
        "research",
        "coding",
        "strategy",
        "compliance",
        "dashboard",
        "business_decision",
        "qa",
        "shipit_readiness",
        "diagnostic"
      ]
    },
    "source_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "date_gathered": {
      "type": "string",
      "format": "date-time"
    },
    "claim_supported": {
      "type": "string",
      "minLength": 1
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freshness_rating": {
      "enum": [
        "fresh",
        "current",
        "stale",
        "unknown"
      ]
    },
    "contradiction_status": {
      "enum": [
        "none_found",
        "contradictions_found",
        "not_checked",
        "unknown"
      ]
    },
    "business_relevance": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "linked_decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "linked_gap": {
      "type": [
        "string",
        "null"
      ]
    },
    "linked_output": {
      "type": [
        "string",
        "null"
      ]
    },
    "recommended_next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "anyOf": [
    {
      "required": [
        "source_path"
      ]
    },
    {
      "required": [
        "source_url"
      ]
    }
  ]
}
