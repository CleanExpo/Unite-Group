# Nexus persistent host — copy to .env and fill (founder enters the secrets).
# Never commit the filled .env.

# Gateway key (from ~/.hermes/.env API_SERVER_KEY).
API_SERVER_KEY=

# Non-loopback exposure guard — REQUIRED when reachable beyond localhost/tailnet.
HERMES_PASSWORD=

# Host paths bind-mounted into the containers.
VAULT_DIR=/home/USER/2nd Brain/2nd Brain
HERMES_ACCOUNTS_DIR=/home/USER/.hermes/accounts

# Presence writer -> prod Supabase (founder-only secret; bridge turn-on, P1).
SUPABASE_URL=https://lksfwktwtmyznckodsau.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
FOUNDER_USER_ID=
